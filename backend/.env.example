APP_NAME="MikroTik SaaS"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=single
LOG_LEVEL=debug

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=mikrotik_saas
DB_USERNAME=laravel
DB_PASSWORD=password

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_CACHE_DB=1
REDIS_QUEUE_DB=2

# Cache & Queue Configuration
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@mikrotik-saas.local"
MAIL_FROM_NAME="${APP_NAME}"

# Authentication
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_TTL=60

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost
SANCTUM_GUARD=sanctum

# AWS (Optional for S3 storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

# Payment Gateways
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
WAVE_API_KEY=

# MikroTik Configuration
MIKROTIK_API_PORT=8728
MIKROTIK_API_SSL_PORT=8729

# VPN Configuration
VPN_WIREGUARD_ENABLED=true
VPN_OPENVPN_ENABLED=true
VPN_L2TP_ENABLED=true

# Mikhmon Cloud
MIKHMON_DOMAIN=mikrotik-saas.local
MIKHMON_STORAGE_PATH=/var/www/mikhmon

# Two Factor Authentication
2FA_ENABLED=true
2FA_WINDOW=1

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_MINUTES=1
