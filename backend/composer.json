{
  "name": "mikrotik-saas-backend",
  "description": "Laravel 12 Backend API for MikroTik SaaS Platform",
  "license": "Proprietary",
  "authors": [
    {
      "name": "MOHAMEDKATE227",
      "role": "Development Team"
    }
  ],
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "laravel/sanctum": "^4.0",
    "laravel/tinker": "^2.9",
    "tymon/jwt-auth": "^2.1",
    "guzzlehttp/guzzle": "^7.8",
    "stripe/stripe-php": "^15.0",
    "laravel-notification-channels/telegram": "^4.3",
    "laravel-notification-channels/whatsapp": "^1.0",
    "barryvdh/laravel-cors": "^2.0",
    "spatie/laravel-permission": "^6.0",
    "spatie/laravel-query-builder": "^5.0",
    "spatie/laravel-activitylog": "^4.7",
    "spatie/laravel-backup": "^8.0",
    "spatie/laravel-medialibrary": "^10.0",
    "laravel/horizon": "^5.0",
    "laravel/passport": "^12.0"
  },
  "require-dev": {
    "pestphp/pest": "^2.0",
    "pestphp/pest-plugin-laravel": "^2.0",
    "laravel/pint": "^1.0",
    "phpstan/phpstan": "^1.0",
    "spatie/laravel-telescope": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-update-cmd": [
      "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ]
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin-laravel": true
    }
  }
}
